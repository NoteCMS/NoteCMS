NODE_ENV=development
JWT_SECRET=change-me

# First admin: created on API startup without a password; complete password in the login UI (or via GraphQL setInitialPassword).
# BOOTSTRAP_ADMIN_EMAIL=you@example.com
# Optional: if set, the “Setup key” field is required when choosing the initial password.
# BOOTSTRAP_SECRET=generate-a-long-random-string

MONGO_URI=mongodb://mongo:27017/notecms
API_PORT=4000
WEB_PORT=5173
ASSET_STORAGE_DRIVER=local
ASSET_LOCAL_ROOT=./data/assets
ASSET_MAX_UPLOAD_BYTES=10000000

# --- deploy/docker-compose.yml (production images) ---
# NOTECMS_API_IMAGE=ghcr.io/your-org/notecms-api:v1.0.0
# NOTECMS_WEB_IMAGE=ghcr.io/your-org/notecms-web:v1.0.0
# Same-origin behind a reverse proxy:
# PUBLIC_URL=https://cms.example.com
# GRAPHQL_PATH=/graphql
# Same host/protocol as the UI, API on another port (recommended on a server — no hardcoded hostname):
# NOTECMS_GRAPHQL_PORT=4000
# Or full browser-reachable GraphQL URL (highest priority; overrides PUBLIC_URL and NOTECMS_GRAPHQL_PORT):
# NOTECMS_GRAPHQL_URL=https://api.example.com/graphql
# Local dev (Vite): optional port-only mode matching docker entrypoint behavior:
# VITE_GRAPHQL_PORT=4000
# Optional host bindings (defaults bind localhost only):
# API_PUBLISH_PORT=127.0.0.1:4000
# WEB_PUBLISH_PORT=127.0.0.1:5173
